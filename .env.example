SECRET_KEY=your-secret-key-here
DEBUG=True
# 로컬: docker-compose.yml 사용 시 → DATABASE_URL은 docker-compose.yml의 environment에서 주입되므로 생략 가능
# Dev EC2: docker-compose.dev.yml 사용 시 → EC2에 설치된 PostgreSQL에 연결 (host networking)
DATABASE_URL=postgres://homen:homen@localhost:5432/homen
ALLOWED_HOSTS=*
CLAUDE_API_KEY=your-claude-api-key-here

# Kakao OAuth2
KAKAO_REST_API_KEY=your-kakao-rest-api-key
KAKAO_REDIRECT_URI=http://localhost:8000/api/v1/auth/kakao/

# Apple Sign In
APPLE_TEAM_ID=your-apple-team-id
APPLE_CLIENT_ID=com.your.app.bundle-id
APPLE_KEY_ID=your-apple-key-id
APPLE_PRIVATE_KEY="-----BEGIN EC PRIVATE KEY-----\nyour-private-key-here\n-----END EC PRIVATE KEY-----"
